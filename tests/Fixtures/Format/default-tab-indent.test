--TEST--
Default configuration: tab indent, newline after tag, blank line between groups and units.
--INPUT--
<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="fr"><file id="messages"><group id="account"><unit id="account.login"><segment state="final"><source>Login</source><target>Connexion</target></segment></unit></group></file></xliff>
--EXPECT--
<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="fr">
	<file id="messages">
		<group id="account">
			<unit id="account.login">
				<segment state="final">
					<source>Login</source>
					<target>Connexion</target>
				</segment>
			</unit>
		</group>
	</file>
</xliff>
