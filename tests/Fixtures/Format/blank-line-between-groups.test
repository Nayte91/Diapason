--TEST--
Inserts a blank line between consecutive <group> siblings (default behaviour).
--INPUT--
<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="fr"><file id="messages"><group id="account"><unit id="account.login"><segment state="final"><source>Login</source></segment></unit></group><group id="navigation"><unit id="nav.home"><segment state="final"><source>Home</source></segment></unit></group></file></xliff>
--EXPECT--
<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="fr">
	<file id="messages">
		<group id="account">
			<unit id="account.login">
				<segment state="final">
					<source>Login</source>
				</segment>
			</unit>
		</group>

		<group id="navigation">
			<unit id="nav.home">
				<segment state="final">
					<source>Home</source>
				</segment>
			</unit>
		</group>
	</file>
</xliff>
