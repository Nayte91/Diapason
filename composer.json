{
    "name": "nayte91/diapason",
    "description": "CLI tool to validate and format XLIFF 2.0/2.1 translation files in Symfony projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "xliff",
        "translation",
        "i18n",
        "symfony",
        "validation",
        "linter",
        "formatter",
        "cli"
    ],
    "authors": [
        {
            "name": "nayte91",
            "email": "nayte91@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/nayte91/diapason/issues",
        "source": "https://github.com/nayte91/diapason"
    },
    "require": {
        "php": ">=8.4",
        "ext-dom": "*",
        "ext-libxml": "*",
        "sebastian/diff": "^6.0",
        "symfony/console": "^8.0",
        "symfony/finder": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Diapason\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Diapason\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/diapason"
    ],
    "scripts": {
        "test": "phpunit",
        "static": "phpstan analyse --memory-limit=512M",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run",
        "ci": [
            "@static",
            "@lint",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
